<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

<!-- ==================== JERSEY SERVLET CONFIGURATION ==================== -->
<!-- Registers Jersey as the handler for all incoming REST requests -->
<!-- This is the entry point that connects Tomcat to our JAX-RS application -->
    
    <servlet>
        <servlet-name>SmartCampusAPI</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>

<!-- Tells Jersey which package to scan for our resource classes -->
<!-- Any class with @Path annotation in this package will be registered -->
        
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus.smartcampusapi</param-value>
        </init-param>

        <load-on-startup>1</load-on-startup>
    </servlet>

<!-- Maps all requests starting with /api/v1/ to the Jersey servlet -->
    
    <servlet-mapping>
        <servlet-name>SmartCampusAPI</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>